<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="curevengers.petit_cure.security.repository.AdminRepository">

    <select id="getUserDetails" resultType="curevengers.petit_cure.security.userdetails.CustomUserDetails">
        SELECT id as username, pass as password
        FROM member
        WHERE id = #{username}
    </select>

</mapper>